{
  // Python Settings
  "python.defaultInterpreterPath": "venv/bin/python",
  "python.formatting.provider": "none",
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "python.linting.enabled": true,
  "python.linting.lintOnSave": true,
  "python.linting.pylintEnabled": false,
  "python.linting.banditEnabled": true,
  "python.linting.flake8Enabled": true,
  "python.linting.flake8Args": [
    "--ignore=E501,E203,W503",
    "--verbose"
  ],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": [
    "tests"
  ],
  "python.autoComplete.extraPaths": [],
  "python.analysis.extraPaths": [],
  "python.analysis.typeCheckingMode": "strict",
  "python.analysis.completeFunctionParens": true,
  "autoDocstring.docstringFormat": "numpy",
  "notebook.outline.showCodeCells": true,
  "notebook.breadcrumbs.showCodeCells": true,
  // Javascript Settings
  "[javascript|json|react]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // HTML and CSS Settings
  "[html|css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // "javascript.format.insertSpaceBeforeFunctionParenthesis": true,
  // C C++ Settings
  "C_Cpp.intelliSenseEngine": "Tag Parser",
  // Markdown Settings
  "markdown.preview.fontFamily": "'Cascadia Mono', -apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', 'Ubuntu', 'Courier New', 'Droid Sans', sans-serif",
  // Editor Settings
  "editor.fontFamily": "'Cascadia Code', 'Cascadia Mono', 'Fira Code', Consolas, 'Courier New', 'Ubuntu Mono', 'Droid Sans Mono', 'monospace', monospace, 'Droid Sans Fallback'",
  "editor.fontSize": 16,
  "editor.fontLigatures": true,
  "editor.formatOnType": true,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.guides.indentation": false,
  "editor.renderWhitespace": "all",
  "editor.codeActionsOnSave": {
    "source.fixAll": false,
    "source.fixAll.eslint": true,
    "source.organizeImports": false
  },
  "vim.smartRelativeLine": true,
  "workbench.colorCustomizations": {
    "terminal.foreground": "#ff0000"
  },
  // Files Settings
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/venv/**": true
  },
  // Others
  "powermode.enabled": true,
  "powermode.shake.intensity": 0,
}
